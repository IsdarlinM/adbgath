include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include LICENSE
include adbgath.sh
recursive-include docs *.md
recursive-include examples *
recursive-include installers *.sh *.cmd *.ps1
recursive-include src/adbgath/web/static *.html *.css *.js
recursive-include src/adbgath/frida/scripts *.js
recursive-include tests *.py
recursive-include .github *.yml
prune build
prune dist
prune .pytest_cache
global-exclude __pycache__ *.py[cod] *.exe *.dll *.so *.dylib *.apk *.apks *.aab *.jar *.pcap *.pcapng
